# ============================================================
# Root .env.example — copy to .env and fill in values
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Never expose publicly

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Research Tracker <reminders@yourdomain.com>

# --- App ---
APP_URL=https://yourusername.github.io/research-tracker

# --- Cron security ---
CRON_SECRET=generate-a-long-random-string-here

# ============================================================
# GitHub Actions Secrets (add to repo Settings > Secrets)
# ============================================================
# VITE_SUPABASE_URL          → same as SUPABASE_URL
# VITE_SUPABASE_ANON_KEY     → same as SUPABASE_ANON_KEY
# SUPABASE_URL               → same as SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY  → same as SUPABASE_SERVICE_ROLE_KEY
# CRON_SECRET                → same as CRON_SECRET
